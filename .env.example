# WorldLens Environment Variables
# Copy this file to .env.local and fill in the values.

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# WebSocket URL (output from CDK deploy)
NEXT_PUBLIC_WS_URL=

# DynamoDB table name (defaults to WorldLensSessions if not set)
SESSIONS_TABLE=WorldLensSessions
